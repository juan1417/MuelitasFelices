@model DashboardPacienteViewModel
@{
    ViewData["Title"] = "Mi Panel";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary"><i class="bi bi-columns-gap"></i> Panel del Paciente</h2>
        <a asp-action="Agendar" class="btn btn-primary rounded-pill px-4">
            <i class="bi bi-plus-circle"></i> Nueva Cita
        </a>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 bg-primary bg-gradient text-white">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white-50">Próximas Citas</h6>
                            <h2 class="fw-bold mb-0">@Model.ProximasCitas</h2>
                        </div>
                        <i class="bi bi-calendar-check fs-1 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-4 bg-success bg-gradient text-white">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white-50">Historial de Citas</h6>
                            <h2 class="fw-bold mb-0">@Model.HistorialCount</h2>
                        </div>
                        <i class="bi bi-clock-history fs-1 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-header bg-white rounded-top-4 py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-calendar-event"></i> Próximas Citas</h5>
        </div>
        <div class="card-body p-0">
            @if (Model.ProximasCitasDetalle.Count == 0)
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-calendar-x fs-1 d-block mb-2"></i>
                    <p class="mb-0">No tienes citas próximas.</p>
                    <a asp-action="Agendar" class="btn btn-primary mt-3 rounded-pill">Agendar una cita</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Doctor</th>
                                <th>Fecha</th>
                                <th>Tipo</th>
                                <th>Estado</th>
                                <th>Motivo</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cita in Model.ProximasCitasDetalle)
                            {
                                <tr>
                                    <td>@cita.MedicoNombre</td>
                                    <td>@cita.FechaHora.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td><span class="badge bg-info">@cita.TipoCita</span></td>
                                    <td>
                                        @switch (cita.Estado)
                                        {
                                            case "Pendiente": <span class="badge bg-warning text-dark">Pendiente</span>; break;
                                            case "Confirmada": <span class="badge bg-success">Confirmada</span>; break;
                                            default: <span class="badge bg-secondary">@cita.Estado</span>; break;
                                        }
                                    </td>
                                    <td class="text-truncate" style="max-width:150px">@cita.Motivo</td>
                                    <td>
                                        <a asp-action="MisCitas" class="btn btn-sm btn-outline-primary rounded-pill">Ver</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
