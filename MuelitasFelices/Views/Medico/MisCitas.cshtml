@model MisCitasViewModel
@{
    ViewData["Title"] = "Mis Citas";
}

<div class="container mt-4">
    <h2 class="fw-bold text-primary mb-4"><i class="bi bi-calendar-check"></i> Mis Citas</h2>

    <ul class="nav nav-tabs mb-4">
        <li class="nav-item">
            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#proximas">
                Próximas <span class="badge bg-primary ms-1">@Model.ProximasCitas.Count</span>
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#historial">
                Historial <span class="badge bg-secondary ms-1">@Model.HistorialCitas.Count</span>
            </button>
        </li>
    </ul>

    <div class="tab-content">
        <div class="tab-pane fade show active" id="proximas">
            @if (!Model.ProximasCitas.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-calendar-x fs-1 d-block mb-2"></i>
                    <p>No hay citas próximas.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Paciente</th>
                                <th>Fecha</th>
                                <th>Tipo</th>
                                <th>Estado</th>
                                <th>Motivo</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cita in Model.ProximasCitas)
                            {
                                <tr>
                                    <td class="fw-bold">@cita.PacienteNombre</td>
                                    <td>@cita.FechaHora.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td><span class="badge bg-info">@cita.TipoCita</span></td>
                                    <td><span class="badge bg-@(cita.Estado == "Pendiente" ? "warning text-dark" : "success")">@cita.Estado</span></td>
                                    <td>@cita.Motivo</td>
                                    <td>
                                        <a asp-action="Historial" asp-route-pacienteId="@cita.PacienteId" asp-route-citaId="@cita.Id"
                                           class="btn btn-sm btn-outline-success rounded-pill">
                                            <i class="bi bi-file-text"></i> Historial
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <div class="tab-pane fade" id="historial">
            @if (!Model.HistorialCitas.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-clock-history fs-1 d-block mb-2"></i>
                    <p>No hay historial.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Paciente</th>
                                <th>Fecha</th>
                                <th>Tipo</th>
                                <th>Estado</th>
                                <th>Motivo</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cita in Model.HistorialCitas)
                            {
                                <tr>
                                    <td>@cita.PacienteNombre</td>
                                    <td>@cita.FechaHora.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td><span class="badge bg-info">@cita.TipoCita</span></td>
                                    <td><span class="badge bg-secondary">@cita.Estado</span></td>
                                    <td>@cita.Motivo</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>
