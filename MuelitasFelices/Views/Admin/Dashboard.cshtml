@model DashboardAdminViewModel
@{
    ViewData["Title"] = "Panel Admin";
}

<div class="container mt-4">
    <h2 class="fw-bold text-primary mb-4"><i class="bi bi-shield-lock"></i> Panel de Administración</h2>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 bg-primary bg-gradient text-white">
                <div class="card-body p-4">
                    <h6 class="text-white-50">Total Usuarios</h6>
                    <h2 class="fw-bold mb-0">@Model.TotalUsuarios</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 bg-success bg-gradient text-white">
                <div class="card-body p-4">
                    <h6 class="text-white-50">Médicos</h6>
                    <h2 class="fw-bold mb-0">@Model.TotalMedicos</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 bg-info bg-gradient text-white">
                <div class="card-body p-4">
                    <h6 class="text-white-50">Pacientes</h6>
                    <h2 class="fw-bold mb-0">@Model.TotalPacientes</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 bg-warning bg-gradient text-white">
                <div class="card-body p-4">
                    <h6 class="text-white-50">Citas Pendientes</h6>
                    <h2 class="fw-bold mb-0">@Model.TotalCitasPendientes</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-header bg-white rounded-top-4 py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold"><i class="bi bi-clock-history"></i> Citas Recientes</h5>
            <a asp-action="Citas" class="btn btn-sm btn-outline-primary rounded-pill">Ver todas</a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Paciente</th>
                            <th>Médico</th>
                            <th>Fecha</th>
                            <th>Tipo</th>
                            <th>Estado</th>
                            <th>Motivo</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var c in Model.CitasRecientes)
                        {
                            <tr>
                                <td>@c.PacienteNombre</td>
                                <td>@c.MedicoNombre</td>
                                <td>@c.FechaHora.ToString("dd/MM/yyyy HH:mm")</td>
                                <td><span class="badge bg-info">@c.TipoCita</span></td>
                                <td>
                                    <span class="badge bg-@(c.Estado == "Pendiente" ? "warning text-dark" : c.Estado == "Confirmada" ? "success" : c.Estado == "Cancelada" ? "danger" : "secondary")">@c.Estado</span>
                                </td>
                                <td>@c.Motivo</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
