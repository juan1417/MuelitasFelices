@model List<MedicoAdminViewModel>
@{
    ViewData["Title"] = "Médicos";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary"><i class="bi bi-heart-pulse"></i> Gestionar Médicos</h2>
        <a asp-action="CrearMedico" class="btn btn-primary rounded-pill px-4">
            <i class="bi bi-plus-circle"></i> Nuevo Médico
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Nombre</th>
                            <th>Email</th>
                            <th>Licencia</th>
                            <th>Especialidades</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in Model)
                        {
                            <tr>
                                <td class="fw-bold">@m.NombreCompleto</td>
                                <td>@m.Email</td>
                                <td>@m.NumeroLicencia</td>
                                <td>
                                    @foreach (var esp in m.Especialidades)
                                    {
                                        <span class="badge bg-info me-1">@esp</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="AsignarEspecialidad" asp-route-medicoId="@m.Id"
                                       class="btn btn-sm btn-outline-primary rounded-pill">
                                        <i class="bi bi-gear"></i> Especialidades
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
