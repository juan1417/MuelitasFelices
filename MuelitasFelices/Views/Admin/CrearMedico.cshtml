@{
    ViewData["Title"] = "Nuevo Médico";
    var especialidades = ViewBag.Especialidades as List<Especialidad> ?? new();
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0 rounded-4">
                <div class="card-header bg-primary text-white rounded-top-4 py-3">
                    <h4 class="mb-0"><i class="bi bi-person-plus"></i> Nuevo Médico</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="CrearMedico" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <input name="nombreCompleto" class="form-control" placeholder="Nombre" required />
                                    <label>Nombre Completo</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <input name="email" class="form-control" type="email" placeholder="Email" required />
                                    <label>Email</label>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <input name="password" class="form-control" type="password" placeholder="Contraseña" required />
                                    <label>Contraseña</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating mb-3">
                                    <input name="telefono" class="form-control" placeholder="Teléfono" required />
                                    <label>Teléfono</label>
                                </div>
                            </div>
                        </div>

                        <div class="form-floating mb-3">
                            <input name="numeroLicencia" class="form-control" placeholder="Licencia" required />
                            <label>Número de Licencia</label>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Especialidades</label>
                            @foreach (var esp in especialidades)
                            {
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="especialidadIds" value="@esp.Id" id="esp_@esp.Id" />
                                    <label class="form-check-label" for="esp_@esp.Id">@esp.Nombre</label>
                                </div>
                            }
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Medicos" class="btn btn-outline-secondary rounded-pill">
                                <i class="bi bi-arrow-left"></i> Volver
                            </a>
                            <button type="submit" class="btn btn-primary rounded-pill px-4">
                                <i class="bi bi-check-lg"></i> Crear Médico
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
