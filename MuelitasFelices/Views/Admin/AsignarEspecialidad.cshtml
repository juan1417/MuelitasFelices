@model List<Especialidad>
@{
    ViewData["Title"] = "Asignar Especialidades";
    var asignadas = ViewBag.EspecialidadesAsignadas as List<int> ?? new();
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 rounded-4">
                <div class="card-header bg-primary text-white rounded-top-4 py-3">
                    <h4 class="mb-0"><i class="bi bi-gear"></i> Especialidades - @ViewBag.MedicoNombre</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="AsignarEspecialidad" method="post">
                        <input type="hidden" name="medicoId" value="@ViewBag.MedicoId" />
                        @foreach (var esp in Model)
                        {
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="checkbox" name="especialidadIds" value="@esp.Id"
                                       id="esp_@esp.Id" @(asignadas.Contains(esp.Id) ? "checked" : "") />
                                <label class="form-check-label" for="esp_@esp.Id">
                                    <strong>@esp.Nombre</strong><br />
                                    <small class="text-muted">@esp.Descripcion</small>
                                </label>
                            </div>
                        }

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-action="Medicos" class="btn btn-outline-secondary rounded-pill">
                                <i class="bi bi-arrow-left"></i> Volver
                            </a>
                            <button type="submit" class="btn btn-primary rounded-pill px-4">
                                <i class="bi bi-save"></i> Guardar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
