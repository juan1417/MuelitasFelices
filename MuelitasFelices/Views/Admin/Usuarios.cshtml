@model List<UsuarioAdminViewModel>
@{
    ViewData["Title"] = "Usuarios";
}

<div class="container mt-4">
    <h2 class="fw-bold text-primary mb-4"><i class="bi bi-people"></i> Gestionar Usuarios</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Nombre</th>
                            <th>Email</th>
                            <th>Teléfono</th>
                            <th>Rol</th>
                            <th>Registro</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model)
                        {
                            <tr>
                                <td class="fw-bold">@u.NombreCompleto</td>
                                <td>@u.Email</td>
                                <td>@u.Telefono</td>
                                <td><span class="badge bg-@(u.Rol == "Admin" ? "danger" : u.Rol == "Medico" ? "success" : "primary")">@u.Rol</span></td>
                                <td>@u.FechaRegistro.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <a asp-action="EditarUsuario" asp-route-id="@u.Id" class="btn btn-sm btn-outline-primary rounded-pill">
                                        <i class="bi bi-pencil"></i> Editar
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
