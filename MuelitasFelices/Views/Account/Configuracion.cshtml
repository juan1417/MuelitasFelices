@model RegisterViewModel
@{
    ViewData["Title"] = "Configuración de Cuenta";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 rounded-4">
                <div class="card-header bg-primary text-white rounded-top-4 py-3">
                    <h4 class="mb-0"><i class="bi bi-gear"></i> Configuración de Cuenta</h4>
                </div>
                <div class="card-body p-4">
                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show">
                            @TempData["Success"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="Configuracion" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="NombreCompleto" class="form-control" placeholder="Nombre" />
                            <label asp-for="NombreCompleto"></label>
                            <span asp-validation-for="NombreCompleto" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Email" class="form-control" placeholder="Email" disabled />
                            <label asp-for="Email"></label>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Telefono" class="form-control" placeholder="Teléfono" />
                            <label asp-for="Telefono"></label>
                            <span asp-validation-for="Telefono" class="text-danger"></span>
                        </div>

                        <hr />
                        <p class="text-muted small">Deja en blanco si no deseas cambiar la contraseña</p>

                        <div class="form-floating mb-3">
                            <input asp-for="Password" class="form-control" placeholder="Nueva contraseña" />
                            <label asp-for="Password">Nueva Contraseña</label>
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirmar" />
                            <label asp-for="ConfirmPassword">Confirmar Contraseña</label>
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-2">
                            <i class="bi bi-check-lg"></i> Guardar Cambios
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
